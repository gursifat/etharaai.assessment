# Path to the SQLite database file.
# For local development you can keep the default `hrms.db` in the project root.
DB_PATH=hrms.db

# Comma-separated list of allowed CORS origins.
# During development you can use '*' or 'http://localhost:5500' etc.
# In production, set this to your actual frontend URL, for example:
# CORS_ORIGINS=https://your-hrms-frontend.netlify.app
CORS_ORIGINS=*

